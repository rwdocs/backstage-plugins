{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "allowedVersions": "<19.0.0",
      "description": "Backstage requires React 18"
    },
    {
      "matchPackageNames": ["react-router-dom"],
      "allowedVersions": "<7.0.0",
      "description": "Backstage requires react-router-dom v6"
    },
    {
      "matchPackageNames": ["express", "@types/express"],
      "allowedVersions": "<5.0.0",
      "description": "Backstage backend API is built on Express v4"
    },
    {
      "matchPackageNames": ["@mui/material"],
      "allowedVersions": "<6.0.0",
      "description": "Backstage requires MUI v5"
    },
    {
      "matchPackageNames": ["typescript"],
      "allowedVersions": "<6.0.0",
      "description": "Backstage pins TypeScript ~5.7"
    },
    {
      "matchPackageNames": ["p-limit"],
      "allowedVersions": "<4.0.0",
      "description": "p-limit v4+ is pure ESM; our CommonJS backend plugin and Backstage's own backend packages stay on v3"
    },
    {
      "matchPackageNames": ["@material-ui/core", "@material-ui/icons"],
      "matchUpdateTypes": ["replacement"],
      "enabled": false,
      "description": "Backstage uses @material-ui/core and @material-ui/icons, not their @mui replacements"
    }
  ]
}
